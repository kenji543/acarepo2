# Environment variables template
# Copy this file to .env for local development and fill in your own values.
# On Railway/production, set these in the host dashboard — do not commit real secrets.

# Django Configuration
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/academic_portfolio_db

# Cloudinary Configuration (from https://console.cloudinary.com/settings/api-keys)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security Settings
SECURE_SSL_REDIRECT=True

# Django Admin (optional bootstrap)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Logging
LOG_LEVEL=INFO
