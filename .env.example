# Environment variables template
# Copy this file to .env and fill in with actual values

# Django Configuration
DEBUG=False
SECRET_KEY=superman123
ALLOWED_HOSTS=

# Database Configuration (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/academic_portfolio_db

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=dzw6x5etr
CLOUDINARY_API_KEY=663392247687695
CLOUDINARY_API_SECRET=zav3JI9z2jofAAht1mF9bvbt6Ek

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com

# Security Settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Django Admin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123
# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_AUTH=5/m
RATE_LIMIT_DOWNLOAD=10/h

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (Optional - for backup)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=academic-portfolio-backups
